---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { breadcrumbSchema } from '../../data/structured-data';

const breadcrumbs = breadcrumbSchema([
  { name: 'Home', url: 'https://www.suirda.ie/' },
  { name: 'Resources', url: 'https://www.suirda.ie/resources' },
  { name: 'Software Decision Guide', url: 'https://www.suirda.ie/resources/software-decision-guide' },
]);
---

<BaseLayout
  title="Free Guide: Custom vs Off-the-Shelf Software"
  description="Download our free decision framework: custom software vs off-the-shelf. Cost comparisons and planning templates for SMEs in Tipperary, Kilkenny & Laois."
  structuredData={breadcrumbs}
>
    <Header />

    <section class="py-20 bg-gradient-to-br from-blue-50 to-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid md:grid-cols-2 gap-12 items-center">
                <div>
                    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
                        Custom Software vs Off-the-Shelf: Decision Guide
                    </h1>
                    <p class="text-lg text-gray-600 mb-6">
                        A practical decision framework for business owners trying to decide between custom software and off-the-shelf solutions.
                    </p>
                    <ul class="space-y-3 text-gray-700 mb-8">
                        <li class="flex items-start">
                            <span class="text-green-600 mr-2 font-bold">✓</span>
                            <span>Decision framework: build vs buy</span>
                        </li>
                        <li class="flex items-start">
                            <span class="text-green-600 mr-2 font-bold">✓</span>
                            <span>Cost comparison at different price points</span>
                        </li>
                        <li class="flex items-start">
                            <span class="text-green-600 mr-2 font-bold">✓</span>
                            <span>Checklist of signs you need custom software</span>
                        </li>
                        <li class="flex items-start">
                            <span class="text-green-600 mr-2 font-bold">✓</span>
                            <span>Timeline and budget planning template</span>
                        </li>
                    </ul>
                </div>

                <div class="bg-white p-8 rounded-lg shadow-sm">
                    <h2 class="text-xl font-semibold mb-4">Download Your Free Copy</h2>
                    <form name="software-guide-download" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="space-y-4">
                        <input type="hidden" name="form-name" value="software-guide-download" />
                        <p class="hidden">
                            <label>Don't fill this out: <input name="bot-field" /></label>
                        </p>
                        <div>
                            <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
                            <input type="text" id="name" name="name" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent" />
                        </div>
                        <div>
                            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
                            <input type="email" id="email" name="email" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent" />
                        </div>
                        <div>
                            <label for="company" class="block text-sm font-medium text-gray-700 mb-1">Company</label>
                            <input type="text" id="company" name="company" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent" />
                        </div>
                        <button type="submit" class="w-full bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition">
                            Download Free Guide
                        </button>
                        <p class="text-xs text-gray-500 text-center">We'll email you the guide. No spam, ever.</p>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <Footer />
</BaseLayout>
