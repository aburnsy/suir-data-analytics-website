---
// Homepage for Suir Data Analytics
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Suir Data Analytics | Business Automation & Custom Software for Tipperary, Kilkenny & Laois SMEs</title>
    <meta name="description" content="Helping Tipperary, Kilkenny & Laois SMEs automate workflows and build custom software that saves time and scales with growth. Local expertise, affordable solutions.">
</head>
<body class="bg-gray-50">
    <!-- Navigation -->
    <nav class="bg-white shadow-sm sticky top-0 z-50">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex-shrink-0">
                    <h1 class="text-2xl font-bold text-blue-600">Suir Data Analytics</h1>
                </div>
                <div class="hidden md:flex space-x-8">
                    <a href="/" class="text-gray-700 hover:text-blue-600">Home</a>
                    <a href="/services" class="text-gray-700 hover:text-blue-600">Services</a>
                    <a href="/case-studies" class="text-gray-700 hover:text-blue-600">Case Studies</a>
                    <a href="/about" class="text-gray-700 hover:text-blue-600">About</a>
                    <a href="/contact" class="text-gray-700 hover:text-blue-600 font-semibold">Contact</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-blue-50 to-white py-20">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center">
                <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
                    Helping Tipperary, Kilkenny & Laois SMEs Automate Workflows and Build Custom Software
                </h2>
                <p class="text-xl text-gray-600 mb-8 max-w-3xl mx-auto">
                    We're a local data and software consultancy that turns manual processes into automated systems — affordably and without the enterprise price tag.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a href="/contact" class="bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700 transition">
                        Book a Free 30-Minute Process Review
                    </a>
                    <a href="/services" class="bg-white text-blue-600 px-8 py-3 rounded-lg font-semibold border-2 border-blue-600 hover:bg-blue-50 transition">
                        See What We Can Automate
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Three Core Value Props -->
    <section class="py-16 bg-white">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <h3 class="text-3xl font-bold text-center text-gray-900 mb-12">How We Help Local SMEs</h3>
            <div class="grid md:grid-cols-3 gap-8">
                <!-- Value Prop 1 -->
                <div class="text-center p-6">
                    <div class="text-4xl mb-4">⚡</div>
                    <h4 class="text-xl font-semibold mb-3">Business Automation That Pays for Itself</h4>
                    <p class="text-gray-600">
                        Automate invoice processing, reporting, inventory sync, and CRM workflows. 
                        Typical ROI: 10+ hours saved per week within 3 months.
                    </p>
                </div>

                <!-- Value Prop 2 -->
                <div class="text-center p-6">
                    <div class="text-4xl mb-4">🛠️</div>
                    <h4 class="text-xl font-semibold mb-3">Custom Software for Unique Business Needs</h4>
                    <p class="text-gray-600">
                        Build bespoke job scheduling, quoting tools, customer portals, and integrations 
                        that fit how your business actually works. From €5k for an MVP.
                    </p>
                </div>

                <!-- Value Prop 3 -->
                <div class="text-center p-6">
                    <div class="text-4xl mb-4">📊</div>
                    <h4 class="text-xl font-semibold mb-3">Phased, Cloud-Based Approach</h4>
                    <p class="text-gray-600">
                        Start small with a pilot project (€2k-5k). Prove ROI before expanding. 
                        No massive upfront investment — scale as you grow.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Mini Case Studies / Wins -->
    <section class="py-16 bg-gray-50">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <h3 class="text-3xl font-bold text-center text-gray-900 mb-12">Recent Wins for Regional SMEs</h3>
            <div class="grid md:grid-cols-3 gap-8">
                <!-- Case Win 1 -->
                <div class="bg-white p-6 rounded-lg shadow-sm">
                    <div class="text-blue-600 font-semibold mb-2">Manufacturing | Tipperary</div>
                    <h4 class="text-lg font-semibold mb-3">Automated Production Reporting</h4>
                    <p class="text-gray-600 mb-4">
                        Built automated dashboards pulling data from production systems, 
                        cutting monthly reporting from 2 days to 2 hours.
                    </p>
                    <div class="text-2xl font-bold text-green-600">10 hours/week saved</div>
                </div>

                <!-- Case Win 2 -->
                <div class="bg-white p-6 rounded-lg shadow-sm">
                    <div class="text-blue-600 font-semibold mb-2">Retail | Kilkenny</div>
                    <h4 class="text-lg font-semibold mb-3">Custom Loyalty & Booking System</h4>
                    <p class="text-gray-600 mb-4">
                        Developed a custom loyalty program integrated with POS, 
                        enabling targeted promotions and online booking.
                    </p>
                    <div class="text-2xl font-bold text-green-600">25% increase in repeat business</div>
                </div>

                <!-- Case Win 3 -->
                <div class="bg-white p-6 rounded-lg shadow-sm">
                    <div class="text-blue-600 font-semibold mb-2">Professional Services | Laois</div>
                    <h4 class="text-lg font-semibold mb-3">Client Onboarding Automation</h4>
                    <p class="text-gray-600 mb-4">
                        Automated workflow from enquiry to contract to project kickoff, 
                        eliminating manual handoffs and email chasing.
                    </p>
                    <div class="text-2xl font-bold text-green-600">2 weeks → 3 days</div>
                </div>
            </div>
            <div class="text-center mt-10">
                <a href="/case-studies" class="text-blue-600 font-semibold hover:underline">
                    View All Case Studies →
                </a>
            </div>
        </div>
    </section>

    <!-- Social Proof -->
    <section class="py-16 bg-blue-600 text-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h3 class="text-2xl font-semibold mb-4">
                Trusted by manufacturers, retailers, and service businesses across the South-East
            </h3>
            <p class="text-blue-100 text-lg">
                We're based locally in the Tipperary/Kilkenny/Laois region, so we understand the reality of running a business here — 
                lean teams, tight budgets, and the need for solutions that work without disrupting operations.
            </p>
        </div>
    </section>

    <!-- Final CTA -->
    <section class="py-20 bg-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h3 class="text-3xl font-bold text-gray-900 mb-6">
                Ready to Automate Your Biggest Manual Headache?
            </h3>
            <p class="text-xl text-gray-600 mb-8">
                Book a free 30-minute call. We'll map your biggest pain points and recommend 2-3 practical next steps.
            </p>
            <a href="/contact" class="inline-block bg-blue-600 text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-blue-700 transition">
                Book Your Free Process Review
            </a>
            <p class="text-gray-500 mt-4">Or email us: <a href="mailto:hello@suirdata.ie" class="text-blue-600 hover:underline">hello@suirdata.ie</a></p>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-400 py-12">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid md:grid-cols-3 gap-8">
                <div>
                    <h4 class="text-white font-semibold mb-4">Suir Data Analytics</h4>
                    <p class="text-sm">
                        Business automation, custom software, data analytics, and AI solutions for SMEs in Tipperary, Kilkenny & Laois.
                    </p>
                </div>
                <div>
                    <h4 class="text-white font-semibold mb-4">Quick Links</h4>
                    <ul class="space-y-2 text-sm">
                        <li><a href="/services" class="hover:text-white">Services</a></li>
                        <li><a href="/case-studies" class="hover:text-white">Case Studies</a></li>
                        <li><a href="/about" class="hover:text-white">About Us</a></li>
                        <li><a href="/contact" class="hover:text-white">Contact</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-white font-semibold mb-4">Contact</h4>
                    <p class="text-sm">
                        Email: <a href="mailto:hello@suirdata.ie" class="hover:text-white">hello@suirdata.ie</a><br>
                        Serving Tipperary, Kilkenny, Laois & surrounding areas
                    </p>
                </div>
            </div>
            <div class="border-t border-gray-800 mt-8 pt-8 text-center text-sm">
                <p>&copy; 2026 Suir Data Analytics. Built with ❤️ in Ireland.</p>
            </div>
        </div>
    </footer>
</body>
</html>